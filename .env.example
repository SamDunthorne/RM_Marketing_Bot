# Copy this file to ".env" for LOCAL testing only.
# In production (GitHub Actions), these are set as encrypted repo secrets instead
# (Settings > Secrets and variables > Actions) -- see docs/SETUP_FACEBOOK_INSTAGRAM.md
# and docs/SETUP_GOOGLE_BUSINESS.md for how to obtain each value.

# --- Meta (Facebook Page + Instagram Business account) ---
FB_PAGE_ID=
FB_PAGE_ACCESS_TOKEN=
IG_BUSINESS_ACCOUNT_ID=

# --- Google Business Profile ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GBP_ACCOUNT_ID=
GBP_LOCATION_ID=

# --- Image hosting base URL ---
# Public URL prefix the bot uses to build image URLs it hands to Meta/Google APIs.
# Default assumes images are committed to this repo and the repo is PUBLIC, served via
# raw.githubusercontent.com. Change this if you host images elsewhere (S3, Cloudinary, etc).
IMAGE_BASE_URL=https://raw.githubusercontent.com/SamDunthorne/RM_Marketing_Bot/main
